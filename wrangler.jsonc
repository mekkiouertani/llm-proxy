{
  "name": "llm-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-30",
  "kv_namespaces": [
    {
      "binding": "SEO_CACHE"
    }
  ],
  "vars": {
    "SEO_CACHE_TTL_SECONDS": "86400",
    "SEO_GENERATION_TIMEOUT_MS": "3500",
    "SEO_TARGET_LANGUAGE": "it",
    "SEO_TARGET_LOCATION_CODE": "2380"
  },
  "observability": {
    "enabled": true
  }
}
