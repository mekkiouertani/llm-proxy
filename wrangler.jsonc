{
  "name": "llm-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-30",
  "kv_namespaces": [
    {
      "binding": "SEO_CACHE"
    },
    {
      "binding": "PRERENDER_CACHE"
    }
  ],
  "browser": {
    "binding": "BROWSER"
  },
  "vars": {
    "SEO_CACHE_TTL_SECONDS": "86400",
    "SEO_GENERATION_TIMEOUT_MS": "12000",
    "PRERENDER_CACHE_TTL_SECONDS": "86400",
    "PRERENDER_TIMEOUT_MS": "12000",
    "SEO_TARGET_LANGUAGE": "it",
    "SEO_TARGET_LOCATION_CODE": "2380",
    "OPENAI_MODEL": "gpt-4.1-mini",
    "ANTHROPIC_MODEL": "claude-sonnet-4-5"
  },
  "observability": {
    "enabled": true
  }
}
